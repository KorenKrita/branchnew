#!/bin/zsh
#
# branchnew — split the current terminal to the right and continue the current
# session there as an independent FORK. Supports both Claude Code and OMP.
#
# Usage:
#   branchnew            split right + fork, auto-named newBranch1, newBranch2, …
#   branchnew <name>     split right + fork, named <name> (verbatim, no number)
#   branchnew --down     split down instead of right (combinable with <name>)
#   branchnew --help     show help
#   branchnew --record   (internal) record pane ↔ session mapping for the hotkey
#                        fork daemons; called by Claude hooks, not by you.
#
# Backend is auto-detected: tmux (real split) > iTerm2 (native split) >
# Ghostty (AppleScript split) > Apple Terminal (can't split → new window) >
# anything else (new Terminal window).
#
# Session backend auto-detected: OMP (via ~/.omp/agent/terminal-sessions/<tty>)
# > Claude Code (via $CLAUDE_CODE_SESSION_ID or branchnew mapping) > fallback.
#
# - Claude Code: `claude --resume <sid> --fork-session --name <name>` (name via flag)
# - OMP: `omp --fork <jsonl>` + terminal-injected `/rename <name>` (name via send-keys,
#   since OMP has no --name flag and hook/extension can't setSessionName at fork time)
#
# The auto counter is stored in ${XDG_STATE_HOME:-~/.local/state}/branchnew/counter.
# OMP fork needs ~1.5-2s TUI startup before /rename can be accepted; the delay is
# BRANCHNEW_OMP_DELAY (default 2).

emulate -L zsh

state="${XDG_STATE_HOME:-$HOME/.local/state}/branchnew"
OMP_SESSIONS="$HOME/.omp/agent/terminal-sessions"
OMP_DELAY="${BRANCHNEW_OMP_DELAY:-2}"

# ── Internal: `branchnew --record` — called by Claude hooks (SessionStart /
# UserPromptSubmit) to remember which Claude session lives in which terminal
# pane. Used by the hotkey fork daemons. Not for interactive use.
# (OMP maintains its own terminal-sessions/<tty> mapping; this is Claude-only.)
if [[ "${1:-}" == "--record" ]]; then
  mkdir -p "$state/iterm" "$state/ghostty" 2>/dev/null

  json_sid="" cwd="" event="" tpath=""
  if [[ ! -t 0 ]]; then
    json="$(cat 2>/dev/null)"
    if [[ -n "$json" ]]; then
      PY="$(command -v python3 || print -- /usr/bin/python3)"
      parsed="$(print -r -- "$json" | "$PY" -c 'import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get("session_id", ""))
    print(d.get("cwd", ""))
    print(d.get("hook_event_name", ""))
    print(d.get("transcript_path", ""))
except Exception:
    print(); print(); print(); print()' 2>/dev/null)"
      lines=("${(@f)parsed}")
      json_sid="${lines[1]:-}"; cwd="${lines[2]:-}"; event="${lines[3]:-}"; tpath="${lines[4]:-}"
    fi
  fi

  tid=""
  [[ -n "$tpath" ]] && tid="${tpath:t:r}"
  sid="${tid:-${CLAUDE_CODE_SESSION_ID:-$json_sid}}"
  [[ -n "$cwd" ]] || cwd="${PWD:-}"

  src="${ITERM_SESSION_ID:-${TERM_SESSION_ID:-}}"
  guid="${src##*:}"
  if [[ -n "$guid" && -n "$sid" ]]; then
    { print -r -- "$sid"; print -r -- "$cwd"; } > "$state/iterm/$guid"
  fi

  gtty=""
  if [[ "${TERM_PROGRAM:-}" == "ghostty" && -n "$sid" ]]; then
    gtty="$(ps -o tty= -p $PPID 2>/dev/null | tr -d ' ')"
    [[ -z "$gtty" || "$gtty" == "??" ]] && gtty="$(ps -o tty= -p $(ps -o ppid= -p $PPID 2>/dev/null | tr -d ' ') 2>/dev/null | tr -d ' ')"
    if [[ -n "$gtty" && "$gtty" != "??" ]]; then
      { print -r -- "$sid"; print -r -- "$cwd"; } > "$state/ghostty/$gtty"
    fi
  fi

  print -r -- "$(date '+%F %T') event=${event:-?} sid=${sid:-NONE} guid=${guid:-NONE} tty=${gtty:-NONE}" >> "$state/record.log" 2>/dev/null
  exit 0
fi

# ── Args: --help → help; --down → split down; rest → name. ────
split_down=0
case "${1:-}" in
  -h|--help|help)
    print -r -- "Usage:"
    print -r -- "  branchnew            split right + fork the current session,"
    print -r -- "                       auto-named newBranch1, newBranch2, … (a counter)"
    print -r -- "  branchnew <name>     same, but name the new session <name>"
    print -r -- "  branchnew --down     split down instead of right"
    print -r -- "  branchnew --help     show this help"
    print -r -- ""
    print -r -- "Backend auto-detected: tmux > iTerm2 > Ghostty > Apple Terminal > new Terminal window."
    print -r -- "Session: OMP (~/.omp/agent/terminal-sessions) > Claude Code (\$CLAUDE_CODE_SESSION_ID)."
    print -r -- "  OMP fork names via terminal-injected /rename (delay \${BRANCHNEW_OMP_DELAY:-2}s)."
    exit 0
    ;;
  --down)
    split_down=1
    shift
    ;;
esac

if (( $# > 0 )); then
  name="$*"
else
  mkdir -p "$state" 2>/dev/null
  counter_file="$state/counter"
  cur="$(cat "$counter_file" 2>/dev/null)"
  [[ "$cur" == <-> ]] || cur=0
  n=$(( cur + 1 ))
  print -r -- "$n" > "$counter_file" 2>/dev/null
  name="newBranch${n}"
fi

print -u2 -r -- "branchnew: new branch session → ${name}"

# ── Detect session backend: OMP vs Claude Code ───────────────────────────────
# Get current tty (for OMP mapping lookup). `tty` returns "not a tty" (with
# spaces) and exits non-zero when there's no controlling tty — e.g. when run
# from inside an OMP /command (the bash tool subprocess has no tty). Walk UP
# the process tree until we find a process whose tty starts with "ttys".
cur_tty=""
cur_tty="$(tty 2>/dev/null)"
if [[ "$cur_tty" == *ttys* ]]; then
  cur_tty="${cur_tty##*/}"
else
  cur_tty=""
  _walk_pid=$$
  for _ in {1..8}; do
    [[ -z "$_walk_pid" || "$_walk_pid" == "1" ]] && break
    _t="$(ps -o tty= -p "$_walk_pid" 2>/dev/null | tr -d ' ')"
    if [[ "$_t" == ttys* ]]; then
      cur_tty="$_t"
      break
    fi
    _walk_pid="$(ps -o ppid= -p "$_walk_pid" 2>/dev/null | tr -d ' ')"
  done
  unset _walk_pid _t
fi

session_backend=""
omp_src=""
claude_sid=""

# 1) OMP: ~/.omp/agent/terminal-sessions/<tty> — line 2 is the jsonl path
if [[ -n "$cur_tty" && -f "$OMP_SESSIONS/$cur_tty" ]]; then
  omp_src="$(sed -n '2p' "$OMP_SESSIONS/$cur_tty" 2>/dev/null)"
  if [[ -n "$omp_src" && -f "$omp_src" ]]; then
    session_backend="omp"
  fi
fi

# 2) Claude Code: $CLAUDE_CODE_SESSION_ID (live env) or branchnew mapping
if [[ -z "$session_backend" ]]; then
  if [[ -n "${CLAUDE_CODE_SESSION_ID:-}" ]]; then
    claude_sid="$CLAUDE_CODE_SESSION_ID"
    session_backend="claude"
  elif [[ -n "$cur_tty" && -f "$state/ghostty/$cur_tty" ]]; then
    claude_sid="$(sed -n '1p' "$state/ghostty/$cur_tty" 2>/dev/null)"
    [[ -n "$claude_sid" ]] && session_backend="claude"
  else
    src="${ITERM_SESSION_ID:-${TERM_SESSION_ID:-}}"
    guid="${src##*:}"
    if [[ -n "$guid" && -f "$state/iterm/$guid" ]]; then
      claude_sid="$(sed -n '1p' "$state/iterm/$guid" 2>/dev/null)"
      [[ -n "$claude_sid" ]] && session_backend="claude"
    fi
  fi
fi

if [[ -z "$session_backend" ]]; then
  print -u2 -r -- "branchnew: no active session found on this pane."
  print -u2 -r -- "  (OMP: no ~/.omp/agent/terminal-sessions/$cur_tty; Claude: no \$CLAUDE_CODE_SESSION_ID / mapping)"
  exit 1
fi

# ── Build the fork command per backend ───────────────────────────────────────
q() { print -r -- "${(q)1}" }

if [[ "$session_backend" == "omp" ]]; then
  # OMP: fork via --fork <jsonl>. Name via terminal-injected /rename (no --name flag).
  # The /rename goes through the TUI input path (input-controller → handleRenameCommand),
  # NOT session.prompt(), so the builtin command executes correctly.
  fork_cmd="cd $(q "$PWD") && omp --fork $(q "$omp_src")"
  rename_cmd="/rename $(q "$name")"
  print -u2 -r -- "branchnew: backend=omp, fork then /rename after ${OMP_DELAY}s"
else
  # Claude Code: --resume <sid> --fork-session --name <name> (name via flag).
  if [[ -n "$claude_sid" ]]; then
    resume_flag="--resume $(q "$claude_sid")"
  else
    resume_flag="--continue"
  fi
  fork_cmd="cd $(q "$PWD") && claude ${resume_flag} --fork-session --name $(q "$name")"
  rename_cmd=""
  print -u2 -r -- "branchnew: backend=claude, --fork-session --name"
fi

# Debug aid: BRANCHNEW_DRYRUN=1 prints what would run and opens nothing.
if [[ -n "${BRANCHNEW_DRYRUN:-}" ]]; then
  local direction="right"; (( split_down )) && direction="down"
  print -r -- "[dry-run] tty=${cur_tty:-none} backend=$session_backend direction=$direction"
  print -r -- "[dry-run] fork:    $fork_cmd"
  [[ -n "$rename_cmd" ]] && print -r -- "[dry-run] rename:  $rename_cmd (after ${OMP_DELAY}s)"
  exit 0
fi

# ── Backends — always a split to the right, or the closest each one can do. ────
# For OMP we send fork_cmd, then sleep, then /rename. For Claude, fork_cmd carries the name.

launch_tmux() {
  local flag="-h"
  (( split_down )) && flag="-v"
  tmux split-window "$flag" -c "$PWD" || return 1
  tmux send-keys "$fork_cmd" Enter
  if [[ -n "$rename_cmd" ]]; then
    # Schedule the /rename after OMP_DELAY into the newly-created pane.
    # tmux: the new pane is at {right} (or {down}) relative to the active pane.
    local target='{right}'
    (( split_down )) && target='{down}'
    ( sleep "$OMP_DELAY" && tmux send-keys -t "$target" "$rename_cmd" Enter ) &!
  fi
}

launch_iterm() {
  local dir="vertical"
  (( split_down )) && dir="horizontal"
  osascript \
    -e 'on run argv' \
    -e 'set cmd to item 1 of argv' \
    -e 'set dir to item 2 of argv' \
    -e 'set hasRename to item 3 of argv' \
    -e 'set renameCmd to item 4 of argv' \
    -e 'set dly to item 5 of argv' \
    -e 'tell application "iTerm"' \
    -e '  activate' \
    -e '  tell current session of current window' \
    -e '    if dir is "horizontal" then' \
    -e '      set s to (split horizontally with default profile)' \
    -e '    else' \
    -e '      set s to (split vertically with default profile)' \
    -e '    end if' \
    -e '  end tell' \
    -e '  tell s to write text cmd' \
    -e '  if hasRename is "1" then' \
    -e '    delay dly' \
    -e '    tell s to write text renameCmd' \
    -e '  end if' \
    -e 'end tell' \
    -e 'end run' \
    "$fork_cmd" "$dir" "${rename_cmd:+1}" "$rename_cmd" "$OMP_DELAY" 2>&1 >/dev/null
}

launch_ghostty() {
  local dir="right"
  (( split_down )) && dir="down"
  # Ghostty AppleScript: input text takes the full string with linefeed.
  # Keep the whole split + (optional) delayed /rename in ONE osascript call so
  # the `newTerm` pane reference stays valid — a second backgrounded osascript
  # would have to re-resolve the pane by focus, which breaks if the user (or
  # focus-stealing) switches panes during the OMP_DELAY window.
  osascript \
    -e 'on run argv' \
    -e 'set cmd to item 1 of argv' \
    -e 'set dir to item 2 of argv' \
    -e 'set hasRename to item 3 of argv' \
    -e 'set renameCmd to item 4 of argv' \
    -e 'set dly to item 5 of argv' \
    -e 'tell application "Ghostty"' \
    -e '  set currentTerm to focused terminal of selected tab of front window' \
    -e '  if dir is "down" then' \
    -e '    set newTerm to split currentTerm direction down' \
    -e '  else' \
    -e '    set newTerm to split currentTerm direction right' \
    -e '  end if' \
    -e '  delay 0.3' \
    -e '  perform action ("text:" & cmd & (ASCII character 13)) on newTerm' \
    -e '  if hasRename is "1" then' \
    -e '    delay dly' \
    -e '    input text renameCmd to newTerm' \
    -e '  end if' \
    -e 'end tell' \
    -e 'end run' \
    "$fork_cmd" "$dir" "${rename_cmd:+1}" "$rename_cmd" "$OMP_DELAY" 2>&1 >/dev/null
}

launch_terminal_window() {
  osascript \
    -e 'on run argv' \
    -e 'set cmd to item 1 of argv' \
    -e 'tell application "Terminal"' \
    -e '  activate' \
    -e '  do script cmd' \
    -e 'end tell' \
    -e 'end run' \
    "$fork_cmd" 2>&1 >/dev/null
  # Terminal can't target a pane for delayed input reliably; skip rename in this mode.
  if [[ -n "$rename_cmd" ]]; then
    print -u2 -r -- "branchnew: (Terminal window mode — auto /rename skipped; run '/rename $name' manually in the new window)"
  fi
}

fail() {
  print -u2 -r -- "branchnew: could not open the new view."
  [[ -n "${1:-}" ]] && print -u2 -r -- "$1"
  print -u2 -r -- "(Is your terminal allowed to run AppleScript? System Settings ›"
  print -u2 -r -- " Privacy & Security › Automation.)"
  exit 1
}

if [[ -n "${TMUX:-}" ]]; then
  launch_tmux || fail "tmux refused to split the window."
  exit 0
fi

case "${TERM_PROGRAM:-}" in
  iTerm.app)
    if ! err="$(launch_iterm)"; then fail "$err"; fi
    ;;
  ghostty)
    if ! err="$(launch_ghostty)"; then fail "$err"; fi
    ;;
  Apple_Terminal)
    print -u2 -r -- "branchnew: Apple Terminal can't split panes — opening a new window instead."
    print -u2 -r -- "          (run inside tmux, or use iTerm2, for a real split.)"
    if ! err="$(launch_terminal_window)"; then fail "$err"; fi
    ;;
  *)
    print -u2 -r -- "branchnew: terminal '${TERM_PROGRAM:-unknown}' can't be scripted directly —"
    print -u2 -r -- "          opening a new Apple Terminal window. For an in-place split, run"
    print -u2 -r -- "          branchnew inside tmux, or use iTerm2."
    if ! err="$(launch_terminal_window)"; then fail "$err"; fi
    ;;
esac

exit 0
