#!/usr/bin/env bash
#
# branchnew — split the current terminal to the right and continue the current
# session there as an independent FORK. Supports both Claude Code and OMP.
#
# Usage:
#   branchnew            split right + fork, auto-named newBranch1, newBranch2, …
#   branchnew <name>     split right + fork, named <name> (verbatim, no number)
#   branchnew --down     split down instead of right (combinable with <name>)
#   branchnew --help     show help
#   branchnew --record   (internal) record pane ↔ session mapping for the hotkey
#                        fork daemons; called by Claude hooks, not by you.
#
# Backend is auto-detected: tmux (real split) > iTerm2 (native split) >
# Ghostty (AppleScript split) > Windows Terminal (wt.exe split-pane) >
# Apple Terminal (can't split → new window) > anything else (new Terminal window).
#
# Session backend auto-detected: OMP (via ~/.omp/agent/terminal-sessions/<tty>)
# > Claude Code (via $CLAUDE_CODE_SESSION_ID or branchnew mapping) > fallback.
#
# - Claude Code: `claude --resume <sid> --fork-session --name <name>` (name via flag)
# - OMP: `omp --fork <jsonl>` + terminal-injected `/rename <name>` (name via send-keys,
#   since OMP has no --name flag and hook/extension can't setSessionName at fork time)
#
# The auto counter is stored in ${XDG_STATE_HOME:-~/.local/state}/branchnew/counter.
# OMP fork needs ~1.5-2s TUI startup before /rename can be accepted; the delay is
# BRANCHNEW_OMP_DELAY (default 2).

set -u

state="${XDG_STATE_HOME:-$HOME/.local/state}/branchnew"
OMP_SESSIONS="$HOME/.omp/agent/terminal-sessions"
OMP_DELAY="${BRANCHNEW_OMP_DELAY:-2}"

# ── Detect the controlling tty (macOS: ttys000, Linux/WSL: pts/3) ──
# `tty` fails with "not a tty" when there's no controlling tty — e.g. inside a
# hook subprocess or an OMP /command. Walk UP the process tree until we find a
# process whose tty is a real pty. Returns the tty WITHOUT /dev/ prefix
# (e.g. "pts/3" or "ttys000"), or empty if none found.
detect_tty() {
  local t wpid
  t="$(tty 2>/dev/null)"
  if [[ "$t" == /dev/ttys* || "$t" == /dev/pts/* ]]; then
    printf '%s' "${t#/dev/}"
    return 0
  fi
  wpid=$$
  for _ in 1 2 3 4 5 6 7 8; do
    [[ -z "$wpid" || "$wpid" == "1" ]] && break
    t="$(ps -o tty= -p "$wpid" 2>/dev/null | tr -d ' ')"
    if [[ "$t" == ttys* || "$t" == pts/* ]]; then
      printf '%s' "$t"
      return 0
    fi
    wpid="$(ps -o ppid= -p "$wpid" 2>/dev/null | tr -d ' ')"
  done
  return 1
}

# ── Internal: `branchnew --record` — called by Claude hooks (SessionStart /
# UserPromptSubmit) to remember which Claude session lives in which terminal
# pane. Used by the hotkey fork daemons. Not for interactive use.
# (OMP maintains its own terminal-sessions/<tty> mapping; this is Claude-only.)
if [[ "${1:-}" == "--record" ]]; then
  mkdir -p "$state/iterm" "$state/ghostty" "$state/claude" 2>/dev/null

  json_sid="" cwd="" event="" tpath=""
  if [[ ! -t 0 ]]; then
    json="$(cat 2>/dev/null)"
    if [[ -n "$json" ]]; then
      PY="$(command -v python3 || printf '/usr/bin/python3')"
      parsed="$(printf '%s' "$json" | "$PY" -c 'import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get("session_id", ""))
    print(d.get("cwd", ""))
    print(d.get("hook_event_name", ""))
    print(d.get("transcript_path", ""))
except Exception:
    print(); print(); print(); print()' 2>/dev/null)"
      # Read 4 lines into variables
      json_sid="$(printf '%s\n' "$parsed" | sed -n '1p')"
      cwd="$(printf '%s\n' "$parsed" | sed -n '2p')"
      event="$(printf '%s\n' "$parsed" | sed -n '3p')"
      tpath="$(printf '%s\n' "$parsed" | sed -n '4p')"
    fi
  fi

  # transcript basename without extension (zsh :t:r equivalent)
  tid=""
  if [[ -n "$tpath" ]]; then
    _base="${tpath##*/}"          # basename
    tid="${_base%.*}"             # strip extension
  fi
  sid="${tid:-${CLAUDE_CODE_SESSION_ID:-$json_sid}}"
  [[ -n "$cwd" ]] || cwd="${PWD:-}"

  src="${ITERM_SESSION_ID:-${TERM_SESSION_ID:-}}"
  guid="${src##*:}"
  if [[ -n "$guid" && -n "$sid" ]]; then
    { printf '%s\n' "$sid"; printf '%s\n' "$cwd"; } > "$state/iterm/$guid"
  fi

  gtty=""
  if [[ "${TERM_PROGRAM:-}" == "ghostty" && -n "$sid" ]]; then
    gtty="$(ps -o tty= -p $PPID 2>/dev/null | tr -d ' ')"
    [[ -z "$gtty" || "$gtty" == "??" ]] && gtty="$(ps -o tty= -p $(ps -o ppid= -p $PPID 2>/dev/null | tr -d ' ') 2>/dev/null | tr -d ' ')"
    if [[ -n "$gtty" && "$gtty" != "??" ]]; then
      { printf '%s\n' "$sid"; printf '%s\n' "$cwd"; } > "$state/ghostty/$gtty"
    fi
  fi

  # WSL/Windows Terminal: record claude mapping keyed by tty (pts-N)
  # so tmux hotkey (branchnew-hotkey) can look it up via pane_tty.
  # Record claude mapping keyed by tty (pts-N), so the tmux-layer hotkey
  # (branchnew-hotkey) can look it up via tmux's pane_tty. Use detect_tty()
  # because hook subprocesses often have no controlling tty of their own.
  if [[ -n "$sid" ]]; then
    _rec_tty="$(detect_tty)"
    if [[ -n "$_rec_tty" ]]; then
      _rec_key="${_rec_tty//\//-}"   # pts/3 -> pts-3 ; ttys000 -> ttys000
      { printf '%s\n' "$sid"; printf '%s\n' "$cwd"; } > "$state/claude/$_rec_key"
    fi
  fi

  printf '%s\n' "$(date '+%F %T') event=${event:-?} sid=${sid:-NONE} guid=${guid:-NONE} tty=${gtty:-NONE}" >> "$state/record.log" 2>/dev/null
  exit 0
fi

# ── Args: --help → help; --down → split down; rest → name. ────
split_down=0
case "${1:-}" in
  -h|--help|help)
    printf '%s\n' "Usage:"
    printf '%s\n' "  branchnew            split right + fork the current session,"
    printf '%s\n' "                       auto-named newBranch1, newBranch2, … (a counter)"
    printf '%s\n' "  branchnew <name>     same, but name the new session <name>"
    printf '%s\n' "  branchnew --down     split down instead of right"
    printf '%s\n' "  branchnew --help     show this help"
    printf '%s\n' ""
    printf '%s\n' "Backend auto-detected: tmux > iTerm2 > Ghostty > Windows Terminal > Apple Terminal > new window."
    printf '%s\n' "Session: OMP (~/.omp/agent/terminal-sessions) > Claude Code (\$CLAUDE_CODE_SESSION_ID)."
    printf '%s\n' "  OMP fork names via terminal-injected /rename (delay \${BRANCHNEW_OMP_DELAY:-2}s)."
    exit 0
    ;;
  --down)
    split_down=1
    shift
    ;;
esac

if (( $# > 0 )); then
  name="$*"
else
  mkdir -p "$state" 2>/dev/null
  counter_file="$state/counter"
  cur="$(cat "$counter_file" 2>/dev/null)"
  [[ "$cur" =~ ^[0-9]+$ ]] || cur=0
  n=$(( cur + 1 ))
  printf '%s\n' "$n" > "$counter_file" 2>/dev/null
  name="newBranch${n}"
fi

printf '%s\n' "branchnew: new branch session → ${name}" >&2

# ── Detect current tty (for OMP/Claude mapping lookup) ──
# detect_tty walks the process tree when there's no controlling tty (e.g.
# inside an OMP /command). Returns "pts/3" or "ttys000" (no /dev/ prefix).
cur_tty="$(detect_tty)"

session_backend=""
omp_src=""
claude_sid=""

# 1) OMP: ~/.omp/agent/terminal-sessions/<tty> — line 2 is the jsonl path.
# Lookup order: tmux panes use their own tty (inherited WT_SESSION points at
# the outer WT pane and would fork the wrong session); a bare Windows Terminal
# pane uses wt-<WT_SESSION> (OMP writes that key file), falling back to tty.
if [[ -n "${TMUX:-}" ]]; then
  # Inside tmux: ONLY the pane's own tty is authoritative.
  if [[ -n "$cur_tty" ]]; then
    _omp_tty_key="${cur_tty//\//-}"   # pts/3 -> pts-3
    if [[ -f "$OMP_SESSIONS/$_omp_tty_key" ]]; then
      omp_src="$(sed -n '2p' "$OMP_SESSIONS/$_omp_tty_key" 2>/dev/null)"
      if [[ -n "$omp_src" && -f "$omp_src" ]]; then
        session_backend="omp"
      fi
    fi
  fi
else
  # Bare terminal (no tmux). On Windows Terminal (WSL), OMP writes a
  # wt-<WT_SESSION> key file — prefer it, then fall back to tty.
  if [[ -n "${WT_SESSION:-}" ]]; then
    _omp_wt_key="wt-${WT_SESSION}"
    if [[ -f "$OMP_SESSIONS/$_omp_wt_key" ]]; then
      omp_src="$(sed -n '2p' "$OMP_SESSIONS/$_omp_wt_key" 2>/dev/null)"
      if [[ -n "$omp_src" && -f "$omp_src" ]]; then
        session_backend="omp"
      fi
    fi
  fi
  if [[ -z "$session_backend" && -n "$cur_tty" ]]; then
    _omp_tty_key="${cur_tty//\//-}"   # pts/3 -> pts-3
    if [[ -f "$OMP_SESSIONS/$_omp_tty_key" ]]; then
      omp_src="$(sed -n '2p' "$OMP_SESSIONS/$_omp_tty_key" 2>/dev/null)"
      if [[ -n "$omp_src" && -f "$omp_src" ]]; then
        session_backend="omp"
      fi
    fi
  fi
fi

# 2) Claude Code: $CLAUDE_CODE_SESSION_ID (live env) or branchnew mapping
if [[ -z "$session_backend" ]]; then
  if [[ -n "${CLAUDE_CODE_SESSION_ID:-}" ]]; then
    claude_sid="$CLAUDE_CODE_SESSION_ID"
    session_backend="claude"
  elif [[ -n "$cur_tty" && -f "$state/ghostty/$cur_tty" ]]; then
    claude_sid="$(sed -n '1p' "$state/ghostty/$cur_tty" 2>/dev/null)"
    [[ -n "$claude_sid" ]] && session_backend="claude"
  else
    src="${ITERM_SESSION_ID:-${TERM_SESSION_ID:-}}"
    guid="${src##*:}"
    if [[ -n "$guid" && -f "$state/iterm/$guid" ]]; then
      claude_sid="$(sed -n '1p' "$state/iterm/$guid" 2>/dev/null)"
      [[ -n "$claude_sid" ]] && session_backend="claude"
    fi
  fi
  # WSL: tty-keyed claude mapping (written by --record above)
  if [[ -z "$session_backend" && -n "$cur_tty" ]]; then
    _claude_tty_key="${cur_tty//\//-}"
    if [[ -f "$state/claude/$_claude_tty_key" ]]; then
      claude_sid="$(sed -n '1p' "$state/claude/$_claude_tty_key" 2>/dev/null)"
      [[ -n "$claude_sid" ]] && session_backend="claude"
    fi
  fi
fi

if [[ -z "$session_backend" ]]; then
  printf '%s\n' "branchnew: no active session found on this pane." >&2
  printf '%s\n' "  (OMP: no $OMP_SESSIONS/<tty>; Claude: no \$CLAUDE_CODE_SESSION_ID / mapping)" >&2
  exit 1
fi

# ── Build the fork command per backend ───────────────────────────────────────
# POSIX single-quote escaping (replaces zsh ${(q)1})
q() { printf "'%s'" "${1//\'/\'\\\'\'}"; }

if [[ "$session_backend" == "omp" ]]; then
  # OMP: fork via --fork <jsonl>. Name via terminal-injected /rename (no --name flag).
  fork_cmd="cd $(q "$PWD") && omp --fork $(q "$omp_src")"
  rename_cmd="/rename $(q "$name")"
  printf '%s\n' "branchnew: backend=omp, fork then /rename after ${OMP_DELAY}s" >&2
else
  # Claude Code: --resume <sid> --fork-session --name <name> (name via flag).
  if [[ -n "$claude_sid" ]]; then
    resume_flag="--resume $(q "$claude_sid")"
  else
    resume_flag="--continue"
  fi
  fork_cmd="cd $(q "$PWD") && claude ${resume_flag} --fork-session --name $(q "$name")"
  rename_cmd=""
  printf '%s\n' "branchnew: backend=claude, --fork-session --name" >&2
fi

# Debug aid: BRANCHNEW_DRYRUN=1 prints what would run and opens nothing.
if [[ -n "${BRANCHNEW_DRYRUN:-}" ]]; then
  direction="right"; (( split_down )) && direction="down"
  printf '%s\n' "[dry-run] tty=${cur_tty:-none} backend=$session_backend direction=$direction"
  printf '%s\n' "[dry-run] fork:    $fork_cmd"
  [[ -n "$rename_cmd" ]] && printf '%s\n' "[dry-run] rename:  $rename_cmd (after ${OMP_DELAY}s)"
  exit 0
fi

# ── Backends — always a split to the right, or the closest each one can do. ────
# For OMP we send fork_cmd, then sleep, then /rename. For Claude, fork_cmd carries the name.

launch_tmux() {
  local flag="-h"
  (( split_down )) && flag="-v"
  local new_pane
  new_pane="$(tmux split-window "$flag" -c "$PWD" -P -F '#{pane_id}' 2>/dev/null)" || return 1
  tmux send-keys -t "$new_pane" "$fork_cmd" Enter
  if [[ -n "$rename_cmd" ]]; then
    # Schedule the /rename after OMP_DELAY into the newly-created pane,
    # targeted by its explicit pane id (robust against focus/layout changes).
    ( sleep "$OMP_DELAY" && tmux send-keys -t "$new_pane" "$rename_cmd" Enter ) &
  fi
}

launch_iterm() {
  local dir="vertical"
  (( split_down )) && dir="horizontal"
  osascript \
    -e 'on run argv' \
    -e 'set cmd to item 1 of argv' \
    -e 'set dir to item 2 of argv' \
    -e 'set hasRename to item 3 of argv' \
    -e 'set renameCmd to item 4 of argv' \
    -e 'set dly to item 5 of argv' \
    -e 'tell application "iTerm"' \
    -e '  activate' \
    -e '  tell current session of current window' \
    -e '    if dir is "horizontal" then' \
    -e '      set s to (split horizontally with default profile)' \
    -e '    else' \
    -e '      set s to (split vertically with default profile)' \
    -e '    end if' \
    -e '  end tell' \
    -e '  tell s to write text cmd' \
    -e '  if hasRename is "1" then' \
    -e '    delay dly' \
    -e '    tell s to write text renameCmd' \
    -e '  end if' \
    -e 'end tell' \
    -e 'end run' \
    "$fork_cmd" "$dir" "${rename_cmd:+1}" "$rename_cmd" "$OMP_DELAY" 2>&1 >/dev/null
}

launch_ghostty() {
  local dir="right"
  (( split_down )) && dir="down"
  osascript \
    -e 'on run argv' \
    -e 'set cmd to item 1 of argv' \
    -e 'set dir to item 2 of argv' \
    -e 'set hasRename to item 3 of argv' \
    -e 'set renameCmd to item 4 of argv' \
    -e 'set dly to item 5 of argv' \
    -e 'tell application "Ghostty"' \
    -e '  set currentTerm to focused terminal of selected tab of front window' \
    -e '  if dir is "down" then' \
    -e '    set newTerm to split currentTerm direction down' \
    -e '  else' \
    -e '    set newTerm to split currentTerm direction right' \
    -e '  end if' \
    -e '  delay 0.3' \
    -e '  perform action ("text:" & cmd & (ASCII character 13)) on newTerm' \
    -e '  if hasRename is "1" then' \
    -e '    delay dly' \
    -e '    input text renameCmd to newTerm' \
    -e '  end if' \
    -e 'end tell' \
    -e 'end run' \
    "$fork_cmd" "$dir" "${rename_cmd:+1}" "$rename_cmd" "$OMP_DELAY" 2>&1 >/dev/null
}

launch_wt() {
  # Windows Terminal (WSL): use wt.exe split-pane. The new pane must re-enter
  # WSL explicitly via wsl.exe (don't rely on profile duplication — the new
  # pane's shell needs to run the fork command directly).
  local dir_flag="-V"   # -V splits vertically => new pane on the right
  (( split_down )) && dir_flag="-H"
  local distro="${WSL_DISTRO_NAME:-}"
  local wsl_args=()
  [[ -n "$distro" ]] && wsl_args+=(-d "$distro")
  # Convert $PWD to a Windows path for --cd (wslpath -w)
  local win_cwd
  win_cwd="$(wslpath -w "$PWD" 2>/dev/null || printf '%s' "$PWD")"
  # Build the command: wsl.exe --cd <cwd> -e bash -lc '<fork_cmd>'
  # The fork_cmd is already shell-quoted; wrap in bash -lc.
  wt.exe split-pane "$dir_flag" -d "$win_cwd" wsl.exe "${wsl_args[@]}" -e bash -lc "$fork_cmd" 2>/dev/null
  # WT can't send delayed /rename to a specific pane reliably; warn for OMP.
  if [[ -n "$rename_cmd" ]]; then
    printf '%s\n' "branchnew: (WT mode — auto /rename skipped; run '/rename $name' manually in the new pane)" >&2
  fi
}

launch_terminal_window() {
  osascript \
    -e 'on run argv' \
    -e 'set cmd to item 1 of argv' \
    -e 'tell application "Terminal"' \
    -e '  activate' \
    -e '  do script cmd' \
    -e 'end tell' \
    -e 'end run' \
    "$fork_cmd" 2>&1 >/dev/null
  # Terminal can't target a pane for delayed input reliably; skip rename in this mode.
  if [[ -n "$rename_cmd" ]]; then
    printf '%s\n' "branchnew: (Terminal window mode — auto /rename skipped; run '/rename $name' manually in the new window)" >&2
  fi
}

fail() {
  printf '%s\n' "branchnew: could not open the new view." >&2
  [[ -n "${1:-}" ]] && printf '%s\n' "$1" >&2
  if [[ "$(uname)" == "Darwin" ]]; then
    printf '%s\n' "(Is your terminal allowed to run AppleScript? System Settings ›" >&2
    printf '%s\n' " Privacy & Security › Automation.)" >&2
  else
    printf '%s\n' "(Check that wt.exe / tmux is available and on PATH.)" >&2
  fi
  exit 1
}

if [[ -n "${TMUX:-}" ]]; then
  launch_tmux || fail "tmux refused to split the window."
  exit 0
fi

case "${TERM_PROGRAM:-}" in
  iTerm.app)
    if ! err="$(launch_iterm)"; then fail "$err"; fi
    ;;
  ghostty)
    if ! err="$(launch_ghostty)"; then fail "$err"; fi
    ;;
  Apple_Terminal)
    printf '%s\n' "branchnew: Apple Terminal can't split panes — opening a new window instead." >&2
    printf '%s\n' "          (run inside tmux, or use iTerm2, for a real split.)" >&2
    if ! err="$(launch_terminal_window)"; then fail "$err"; fi
    ;;
  *)
    # WSL / Windows Terminal: WT_SESSION is set when running inside Windows Terminal.
    if [[ -n "${WT_SESSION:-}" ]] || command -v wt.exe >/dev/null 2>&1; then
      if ! err="$(launch_wt)"; then fail "$err"; fi
    elif [[ "$(uname)" == "Darwin" ]]; then
      printf '%s\n' "branchnew: terminal '${TERM_PROGRAM:-unknown}' can't be scripted directly —" >&2
      printf '%s\n' "          opening a new Apple Terminal window. For an in-place split, run" >&2
      printf '%s\n' "          branchnew inside tmux, or use iTerm2." >&2
      if ! err="$(launch_terminal_window)"; then fail "$err"; fi
    else
      fail "no supported terminal backend (install tmux, or run inside Windows Terminal)."
    fi
    ;;
esac

exit 0
